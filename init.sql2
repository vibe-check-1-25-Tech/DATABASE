#backhand
CREATE TABLE Audit_Logs (
  aud_id INTEGER PRIMARY KEY AUTO_INCREMENT,
  action_type VARCHAR(50),
  actor_id INTEGER,
  timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (actor_id) REFERENCES Users(user_id)
);