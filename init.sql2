CREATE DATABASE IF NOT EXISTS
mood_tracker;
USE mood_tracker;
#AUTO_INCREMENT  чтобы id создавался сам
CREATE TABLE Users (
  user_id INTEGER PRIMARY KEY AUTO_INCREMENT,
  username VARCHAR(100) NOT NULL,
  email VARCHAR(100) NOT NULL,
  password_hash VARCHAR(255) NOT NULL,
  created_at DATE
);
INSERT INTO Users (user_id, username, email, password_hash,  created_at) VALUES
(1, 'MackLovin', 'MackLovin@email.com', 'hash123', '2026-10-01'),
(2, 'Jungkook', 'Jungkook@email.com', 'hash1234', '2025-11-03');

CREATE TABLE Mood_Logs (
  log_id INTEGER PRIMARY KEY AUTO_INCREMENT,
  user_id INTEGER,
  score INTEGER NOT NULL,
  note VARCHAR(1000),
  timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (user_id) REFERENCES Users(user_id) ON DELETE CASCADE
); # ON DELETE CASCADE удвление пользователя удалит все его логи, записи и тд.

INSERT INTO Mood_Logs (log_id, user_id, score, note) VALUES
(1, 1, 1, 'Отличный день'),
(2, 1, 5, 'Немного устал'),
(3, 2, 4, 'Хорошее настроение'),
(4, 2, 3, 'Плохой день'),
(5, 1, 2, 'Очень продуктивный день');


CREATE TABLE Tags (
  tag_id INTEGER PRIMARY KEY AUTO_INCREMENT,
  tag_name VARCHAR(50) UNIQUE,
  emoji VARCHAR(10),
  tag_type VARCHAR(50)
);

INSERT INTO Tags (tag_id, tag_name, emoji, tag_type) VALUES
(1, 'happy', '😊', 'positive' ),
(2, 'Sad', '😢', 'negative'),
(3, 'Angry', '😡', 'negative'),
(4, 'Calm', '😌', 'neutral'),
(5, 'Anxious', '😰', 'negative');

CREATE TABLE Log_Tags(
  log_id INTEGER,
  tag_id INTEGER,
  PRIMARY KEY (log_id, tag_id),
  FOREIGN KEY (log_id) REFERENCES Mood_Logs(log_id) ON DELETE CASCADE,
  FOREIGN KEY (tag_id) REFERENCES Tags(tag_id) ON DELETE CASCADE
);

INSERT INTO Log_Tags (log_id, tag_id) VALUES
(1, 1),
(2, 5),
(3, 4),
(4, 2),
(5, 1);

CREATE TABLE Teams(
  team_id INTEGER PRIMARY KEY AUTO_INCREMENT,
  team_name VARCHAR(50) NOT NULL,
  team_description VARCHAR(100),
  created_by INTEGER,
  FOREIGN KEY (created_by) REFERENCES Users(user_id) ON DELETE SET NULL
);

INSERT INTO Teams (team_id, team_name, team_description, created_by) VALUES
(1, 'Support Team', 'Команда поддержки', 1),
(2, 'Wellness Group', 'Группа благополучия', 2),
(3, 'MindCare', 'Забота о ментальном здоровье', 1),
(4, 'Daily Motivation', 'Мотивация каждый день', 2),
(5, 'Calm Minds', 'Спокойствие и баланс', 1);

CREATE TABLE Team_Members(
  team_id INTEGER,
  user_id INTEGER,
  role VARCHAR(50) DEFAULT 'member',
  PRIMARY KEY (team_id, user_id),
  FOREIGN KEY (team_id) REFERENCES Teams(team_id) ON DELETE CASCADE,
  FOREIGN KEY (user_id) REFERENCES Users(user_id) ON DELETE CASCADE
);

INSERT INTO Team_Members (team_id, user_id, role) VALUES
(1, 1, 'admin'),
(1, 2, 'member'),
(2, 2, 'member'),
(3, 1, 'admin'),
(4, 2, 'member');

CREATE TABLE Resources (
  res_id INTEGER PRIMARY KEY,
  title VARCHAR(100),
  url VARCHAR(255),
  res_description VARCHAR(100),
  category VARCHAR(50)
);

